      "transform": "location_state"
    },
    {
      "id": "country",
      "labelPatterns": [
        "country"
      ],
      "source": "profile",
      "profilePath": "personal_info.location",
      "transform": "location_country"
    },
    {
      "id": "address_location",
      "labelPatterns": [
        "address",
